# Copy this file to .env for local development.
# Never commit real service-role keys or production secrets.

VITE_PUBLIC_BUILDER_KEY=
PING_MESSAGE="ping"

# Frontend-safe Supabase values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase values. Required by Express API routes.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Deployment/CORS. Keep this restricted; never use "*".
PUBLIC_SITE_URL=http://laundrykingWDF.com
CORS_ORIGINS=http://laundrykingWDF.com
